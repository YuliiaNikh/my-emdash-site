---
import { getEmDashEntry } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import "../styles/pages/home.scss";

const { entry: home, cacheHint } = await getEmDashEntry("homepage", "home");
Astro.cache.set(cacheHint);

const d = home?.data ?? {} as any;

const heroHeading = d.hero_heading || "Empowering Israeli Businesses. Creating Jobs. Strengthening Israel.";
const heroDescription = d.hero_description || "IBF – Israel Business Fund provides growth and equipment grants to established Israeli businesses, with a focus on Judea and Samaria.";
const heroCta = { label: d.hero_cta_label || "Apply for an IBF Grant", url: d.hero_cta_url || "/apply" };
const heroSecondary = { label: d.hero_secondary_label || "Learn More", url: d.hero_secondary_url || "/about" };

const missionHeading = d.mission_heading || "IBF – Israel Business Fund supports existing Israeli businesses that are ready to scale, expand operations, and create jobs.";
const missionDescription = d.mission_description || "We believe in the highest form of giving — empowering people through enterprise, not short-term aid. Our grants help businesses purchase equipment, improve infrastructure, and unlock long-term economic growth.";

const howHeading = d.how_heading || "How It Works";
const steps = [
	d.step_1_text || "Eligible businesses download and complete the IBF grant application",
	d.step_2_text || "Applications are reviewed by IBF leadership and local representatives",
	d.step_3_text || "Approved grants are paid directly to vendors, ensuring transparency and accountability",
];
const howCta = { label: d.how_cta_label || "Apply for an IBF Grant", url: d.how_cta_url || "/apply" };

const impactHeading = d.impact_heading || "Our Impact";
const stats = [
	{ number: d.stat_1_number ?? 1275, label: d.stat_1_label || "Businesses Supported", color: "blue" },
	{ number: d.stat_2_number ?? 364, label: d.stat_2_label || "Jobs Created", color: "gold" },
	{ number: d.stat_3_number ?? 90233, label: d.stat_3_label || "(₪) Granted", color: "green" },
	{ number: d.stat_4_number ?? 24, label: d.stat_4_label || "Communities Strengthened", color: "gray" },
];
const impactCta = { label: d.impact_cta_label || "Learn more about IBF's impact", url: d.impact_cta_url || "/impact" };

const stepIcons = ["/images/icon-document.svg", "/images/icon-check.svg", "/images/icon-money.svg"];

const galleryImages = {
	large: d.gallery_image_1,
	small1: d.gallery_image_2,
	small2: d.gallery_image_3,
	tall: d.gallery_image_4,
};
---

<Base
	title={d.title || "IBF - Israel Business Fund"}
	description={heroDescription}
>
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero__bg">
			{d.hero_image ? (
				<Image image={d.hero_image} class="hero__bg-image" loading="eager" />
			) : (
				<img src="/images/hero-bg.jpg" alt="" class="hero__bg-image" loading="eager" />
			)}
			<div class="hero__gradient"></div>
		</div>
		<div class="hero__content">
			<div class="hero__text anim-hero" style="--delay: 0">
				<h1 class="hero__heading" set:html={heroHeading.replace(/^(\S+)/, '<span class="hero__heading-decorated">$1</span>')} />
				<p class="hero__description">{heroDescription}</p>
			</div>
			<div class="hero__buttons anim-hero" style="--delay: 1">
				<a href={heroCta.url} class="ibf-btn ibf-btn--gold ibf-btn--lg">{heroCta.label}</a>
				<a href={heroSecondary.url} class="ibf-btn ibf-btn--outline-white ibf-btn--lg">{heroSecondary.label}</a>
			</div>
		</div>
	</section>

	<!-- Mission Section -->
	<section class="mission">
		<div class="mission__container">
			<div class="mission__text" data-reveal>
				<h2 class="mission__heading">{missionHeading}</h2>
				<p class="mission__description">{missionDescription}</p>
			</div>

			<div class="mission__gallery" data-reveal data-reveal-delay="200">
				<div class="mission__gallery-large">
					{galleryImages.large ? (
						<Image image={galleryImages.large} loading="lazy" />
					) : (
						<img src="/images/gallery-1.jpg" alt="Israeli business owner at work" loading="lazy" />
					)}
				</div>
				<div class="mission__gallery-grid">
					<div class="mission__gallery-col">
						<div class="mission__gallery-item">
							{galleryImages.small1 ? (
								<Image image={galleryImages.small1} loading="lazy" />
							) : (
								<img src="/images/gallery-2.jpg" alt="Business collaboration" loading="lazy" />
							)}
						</div>
						<div class="mission__gallery-item">
							{galleryImages.small2 ? (
								<Image image={galleryImages.small2} loading="lazy" />
							) : (
								<img src="/images/gallery-3.jpg" alt="Team working together" loading="lazy" />
							)}
						</div>
					</div>
					<div class="mission__gallery-tall">
						{galleryImages.tall ? (
							<Image image={galleryImages.tall} loading="lazy" />
						) : (
							<img src="/images/gallery-5.jpg" alt="Business professional" loading="lazy" />
						)}
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- How It Works Section -->
	<section class="how-it-works">
		<div class="how-it-works__container">
			<h2 class="how-it-works__heading" data-reveal>{howHeading}</h2>

			<div class="how-it-works__cards">
				{steps.map((text, i) => (
					<div class="how-it-works__card" data-reveal data-reveal-delay={String(i * 150)}>
						<img src={stepIcons[i]} alt="" class="how-it-works__icon" />
						<p class="how-it-works__card-text">{text}</p>
					</div>
				))}
			</div>

			<a href={howCta.url} class="ibf-btn ibf-btn--outline-dark ibf-btn--lg" data-reveal data-reveal-delay="400">{howCta.label}</a>
		</div>
	</section>

	<!-- Our Impact Section -->
	<section class="impact">
		<div class="impact__container">
			<h2 class="impact__heading" data-reveal>{impactHeading}</h2>

			<div class="impact__stats">
				{stats.map((stat, i) => (
					<div class={`impact__stat impact__stat--${stat.color}`} data-reveal data-reveal-delay={String(i * 150)}>
						<p class="impact__stat-number" data-count-up={String(stat.number)}>0</p>
						<p class="impact__stat-label">{stat.label}</p>
					</div>
				))}
			</div>

			<a href={impactCta.url} class="ibf-btn ibf-btn--outline-dark ibf-btn--lg" data-reveal data-reveal-delay="500">{impactCta.label}</a>
		</div>
	</section>
</Base>

<script src="../scripts/home.ts"></script>
